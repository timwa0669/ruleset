hostname = mangaapi.manhuaren.com, www.linovelib.com, w.linovelib.com

# Manhuaren
^https?:\/\/mangaapi\.manhuaren\.com\/v\d\/ad\/ url reject
^https?:\/\/mangaapi\.manhuaren\.com\/v\d\/public\/getStartPageAds url reject
